# 🚀 Frontend Dashboard Configuration
# Template for Vercel Environment Variables

# 📡 Primary Backend Resource Hub
# For Production (Render): https://empdash.onrender.com/api
# For Local Development: (Leave blank to use internal Vite proxy /api)
VITE_API_URL=https://empdash.onrender.com/api

# 🛠️ Configuration Strategy
VITE_APP_NAME="EmpDash 2.0"
VITE_APP_ENV=production

# Note: Vercel might automatically handle VITE_ variables if configured.
# Do NOT prefix with "REACT_APP" as this is a Vite-based synchronization.
