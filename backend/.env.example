# 🌐 Backend Hub Environment Configuration
# Use this as a template for your .env file on Render and Local Machine

# 📡 Cloud Cluster Strategy (Turso LibSQL)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-very-long-auth-token

# 🔐 Security Protocols (JWT Synchronization)
JWT_SECRET=super-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# 🌐 Digital Lifecycle Interface
# Set to the port required by Render or fallback to 5000 for local use
PORT=5000
NODE_ENV=production

# 📶 Networking Policy
# Update this to your deployed Vercel domain to secure the CORS handshake
FRONTEND_URL=https://emp-dash-seven.vercel.app
